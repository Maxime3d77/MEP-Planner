# ==========================================================
# MEP Planner v2.8 — Configuration complète
# Copiez ce fichier : cp .env_template .env
# Ne versionnez jamais le fichier .env.
# ==========================================================

# Application
TZ=Europe/Paris
# Langue globale des emails et PDF : fr ou en
APP_LANGUAGE=fr
# Langue des emails et PDF : fr ou en
COMMUNICATION_LANGUAGE=fr
# Thème initial de l’interface : dark ou light
APP_THEME=dark

# Administration des paramètres
# Utilisez un mot de passe long et unique. Laisser vide désactive les modifications.
ADMIN_PASSWORD=change_this_admin_password
ADMIN_SESSION_HOURS=8

# Dépôt officiel et contrôle des mises à jour
GITHUB_REPOSITORY_URL=https://github.com/Maxime3d77/MEP-Planner
GITHUB_API_REPOSITORY=Maxime3d77/MEP-Planner
GITHUB_CHECK_TIMEOUT_SECONDS=8

# Redmine
REDMINE_URL=https://redmine.example.fr
REDMINE_API_KEY=change_me
REDMINE_TAG_FIELD=Tag
REDMINE_TAG_VALUE=MEP
REDMINE_ENV_FIELD=Environnement
REDMINE_START_TIME_FIELD=Heure de début
REDMINE_END_TIME_FIELD=Heure de fin
ALLOW_DEMO=false

# Synchronisation Redmine
POLL_INTERVAL_SECONDS=300
MAX_REDMINE_PAGES=50

# Statuts considérés comme terminés
DONE_STATUSES=Done;Closed;Terminé;Terminée;Résolu;Resolved

# SMTP
SMTP_ENABLED=false
SMTP_HOST=smtp.example.fr
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=MEP Planner <mep-planner@example.fr>
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
# Séparer plusieurs destinataires par un point-virgule.
SMTP_RECIPIENTS=exploitation@example.fr

# Résumé quotidien
DAILY_EMAIL_ENABLED=true
DAILY_EMAIL_HOUR=8
DAILY_EMAIL_MINUTE=0

# Identité permanente MEP Planner
BRAND_NAME=MEP Planner
BRAND_SUBTITLE=Pilotage des mises en production
BRAND_ACCENT=#5B7CFA
BRAND_LOGO_PATH=/app/branding/logo.png

# Valeurs initiales du branding entreprise.
# Elles peuvent ensuite être modifiées depuis le menu Paramètres.
COMPANY_NAME=My Company
COMPANY_SUBTITLE=IT Operations
COMPANY_ACCENT=#5B7CFA
COMPANY_CONTACT_EMAIL=
COMPANY_FOOTER=

# Public MEP Planner URL (optional)
APP_PUBLIC_URL=https://mep-planner.example.com

# Matrix integration
MATRIX_ENABLED=false
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_ACCESS_TOKEN=
MATRIX_ROOM_ID=!roomId:example.com
MATRIX_NOTIFY_NEW=true
MATRIX_NOTIFY_CHANGED=true
MATRIX_NOTIFY_DAILY=false

# Administration v3.3
AUTH_REQUIRED=false
REDMINE_VERIFY_TLS=true
REDMINE_TIMEOUT_SECONDS=20
SMTP_SECURITY=none
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=https://sso.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=mep-planner
OIDC_CLIENT_SECRET=
# LDAP / Active Directory (defaults; settings saved in the UI take precedence)
LDAP_ENABLED=false
LDAP_NAME=Enterprise directory
LDAP_DIRECTORY_TYPE=openldap
LDAP_URL=ldaps://ldap.example.com
LDAP_PORT=636
LDAP_BIND_DN=cn=ldap-reader,ou=Services,dc=example,dc=com
LDAP_BIND_PASSWORD=change_me
LDAP_VERIFY_TLS=true
LDAP_JIT_PROVISIONING=true
LDAP_USER_BASE_DN=ou=People,dc=example,dc=com
LDAP_USER_LOGIN_ATTRIBUTE=uid
LDAP_USER_FILTER=(&(objectClass=person)(uid={username}))
LDAP_USER_FIRSTNAME_ATTRIBUTE=givenName
LDAP_USER_LASTNAME_ATTRIBUTE=sn
LDAP_USER_EMAIL_ATTRIBUTE=mail
LDAP_GROUP_BASE_DN=ou=Groups,dc=example,dc=com
LDAP_GROUP_OBJECT_CLASS=posixGroup
LDAP_GROUP_NAME_ATTRIBUTE=cn
LDAP_GROUP_MEMBER_ATTRIBUTE=memberUid
LDAP_GROUP_REFERENCE_ATTRIBUTE=uid
LDAP_GROUP_FILTER=({member_attribute}={reference})
# Format: group:user;group-admin:admin
LDAP_GROUP_MAP=operations:user;mep-admins:admin

